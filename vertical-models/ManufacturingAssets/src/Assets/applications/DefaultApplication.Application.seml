_package: Assets.applications
_type: Application
_name: DefaultApplication
label: Asset Management
visibility: VISIBLE
applicationTitle: Asset Management
avatarImageUrl: images://manuf-asset-management/manufacturing.png
logoUrl: images://default/manuf-asset-management/manufacturing.png
coverImageUrl: images://manuf-asset-management/Cover-1.jpeg
favIcon: images://manuf-asset-management/manufacturing.png
sortStrategy: POSITION
historyBrowsingEnabled: false 
historyBrowsingRequiredRole: ""
defaultAction: Assets.applications.DefaultApplication.Root.GeneralActions.GlobalSearch
documentationConfig:
  documentation: This application is used to manage assets, locations, machines, IoT devices, and related reference data.
  documentationConfigDiagrams:
    - _type: DocumentationConfigDiagram
      _name: Main
      modelDiagram: Assets.model_diagrams.Assets
globalSearchConfig:
  displaySearchForDropdown: true
  sortBusinessViewsAlphabetically: true
  globalSearchBusinessViews:
    - _type: GlobalSearchBoView
      _name: Factories
      viewType: GD
      businessView: Assets.entities.Factory.business_views.FactoryBusinessView
      searchTypeConfig: Assets.entities.Factory.business_views.FactoryBusinessView.Factory.TextConfig
      maxResults: 10
      label: Factories
    - _type: GlobalSearchBoView
      _name: ProductionLines
      viewType: GD
      businessView: Assets.entities.ProductionLine.business_views.ProductionLineBusinessView
      searchTypeConfig: Assets.entities.ProductionLine.business_views.ProductionLineBusinessView.ProductionLine.TextConfig
      maxResults: 10
      label: Production Lines
    - _type: GlobalSearchBoView
      _name: Machines
      businessView: Assets.entities.Machine.business_views.MachineBusinessView
      searchTypeConfig: Assets.entities.Machine.business_views.MachineBusinessView.Machine.TextConfig
      viewType: GD
      label: Machines
      maxResults: 10      
    - _type: GlobalSearchBoView
      _name: Products
      businessView: Assets.entities.Product.business_views.ProductBusinessView
      searchTypeConfig: Assets.entities.Product.business_views.ProductBusinessView.Product.TextConfig
      viewType: GD
      label: Products
      maxResults: 10
    - _type: GlobalSearchBoView
      _name: SpareParts
      viewType: GD
      businessView: Assets.entities.SparePart.business_views.SparePartBusinessView
      searchTypeConfig: Assets.entities.SparePart.business_views.SparePartBusinessView.SparePart.TextConfig
      label: Spare Parts

navDrawer:
  - _type: FolderNavGroup
    _name: GeneralActions
    dividerVisible: true
    labelVisible: false
    linkedFolder: Assets.applications.DefaultApplication.Root.GeneralActions
  - _type: FolderNavGroup
    _name: Production
    dividerVisible: true
    labelVisible: false
    linkedFolder: Assets.applications.DefaultApplication.Root.Production
  - _type: FolderNavGroup
    _name: Maintenance
    dividerVisible: true
    labelVisible: false
    linkedFolder: Assets.applications.DefaultApplication.Root.Maintenance
  - _type: FolderNavGroup
    _name: DocumentationFolder
    dividerVisible: true
    labelVisible: false
    linkedFolder: Assets.applications.DefaultApplication.Root.Administration

rootFolder:
  _type: FolderAction
  _name: Root
  label: Root Folder
  image: images://mdi/folder.svg
  imageAlign: MIDDLE_CENTER
  imageMode: FIT
  appActions:
    - _type: FolderAction
      _name: GeneralActions
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      label: Quick links
      appActions:
        - _type: GlobalSearchAction
          _name: GlobalSearch
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          description: Search across all entities
          iconColor: md:green
        - _type: MyTasksAction
          _name: MyTasks
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          badgeVisible: true
          description: View my tasks
          image: images://mdi/inbox-multiple.svg
          iconColor: md:green
    - _type: FolderAction
      _name: Production
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      label: Production & assets
      appActions:
        - _type: BrowseBusinessViewAction
          _name: BrowseFactory
          businessView: Assets.entities.Factory.business_views.FactoryBusinessView
          label: Factories
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse Factory records
          image: images://mdi/factory.svg
          iconColor: md:blue
        - _type: BrowseBusinessViewAction
          _name: BrowseProductionLines
          businessView: Assets.entities.ProductionLine.business_views.ProductionLineBusinessView
          label: Production Lines
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse Production Line records
          image: images://mdi/robot-industrial.svg
          iconColor: md:blue
        - _type: BrowseBusinessViewAction
          _name: BrowseMachines
          businessView: Assets.entities.Machine.business_views.MachineBusinessView
          label: Machines
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse Machine records
          image: images://mdi/cogs.svg
          iconColor: md:blue
        - _type: FolderAction
          _name: Others
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          label: Others
          description: Access other asset related entities
          image: images://mdi/folder.svg
          iconColor: md:blue
          appActions:
            - _type: BrowseBusinessViewAction
              _name: BrowseDigitalTwins
              businessView: Assets.entities.DigitalTwin.business_views.DigitalTwinBusinessView
              label: Digital Twins
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              description: Browse Digital Twin records
              image: images://mdi/swap-horizontal-circle.svg
              iconColor: md:blue
            - _type: BrowseBusinessViewAction
              _name: BrowseIoTDevices
              businessView: Assets.entities.IoTDevice.business_views.IoTDeviceBusinessView
              label: IoT Devices
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              description: Browse IoT Device records
              image: images://mdi/ip-network.svg
              iconColor: md:blue
            - _type: BrowseBusinessViewAction
              _name: BrowseProducts
              businessView: Assets.entities.Product.business_views.ProductBusinessView
              label: Products
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              description: Browse Product records
              iconColor: md:blue
              image: images://mdi/package-variant-closed.svg
    - _type: FolderAction
      _name: Maintenance
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      label: Maintenance & Parts
      appActions:
        - _type: BrowseBusinessViewAction
          _name: BrowseMaintenanceSchedule
          businessView: Assets.entities.MaintenanceSchedule.business_views.MaintenanceScheduleBusinessView
          label: Maintenance Schedules
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse Maintenance Schedule records
          image: images://mdi/clipboard-clock-outline.svg
          iconColor: md:orange
        - _type: BrowseBusinessViewAction
          _name: BrowseSpareParts
          businessView: Assets.entities.SparePart.business_views.SparePartBusinessView
          label: Spare Parts
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse Spare Part records
          image: images://mdi/toy-brick-search-outline.svg
          iconColor: md:orange
        - _type: BrowseBusinessViewAction
          _name: BrowseSuppliers
          businessView: Assets.entities.Supplier.business_views.SupplierBusinessView
          label: Suppliers
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse Supplier records
          image: images://mdi/book-account-outline.svg
          iconColor: md:orange

    - _type: FolderAction
      _name: Administration
      
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      description: Administrative tasks
      label: Administration
      image: images://mdi/bookshelf.svg
      appActions:
        - _type: FolderAction
          _name: AdministrationFolder
          label: Admin & Documentation
          image: images://mdi/bookshelf.svg
          icon: images://mdi/bookshelf.svg
          iconColor: md:grey
          labelColor: md:grey
          appActions:
            - _type: OpenDocumentationAction
              _name: OpenModelDoc
              iconColor: md:grey
              label: Model Documentation
            - _type: BrowseEntitiesFolderAction
              _name: Entities
              lineageEnabled: true
            - _type: FolderAction
              _name: ImportData
              icon: images://mdi/database-import.svg
              image: images://default/folder-item-import.png
              iconColor: md:grey
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              label: Import Data
              requiredRole: SemAdmin
              appActions:
                - _type: ImportDataAppAction
                  _name: ImportCountry
                  label: Import Country
                  image: images://default/folder-item-import.png
                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.Country.action_sets.CountryActionSet.ImportAuthorCountries

                - _type: ImportDataAppAction
                  _name: ImportFactoryType
                  label: Import Factory Type
                  image: images://default/folder-item-import.png
                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.FactoryType.action_sets.FactoryTypeActionSet.ImportAuthorFactoryTypes
                - _type: ImportDataAppAction
                  _name: ImportCriticalityLevel
