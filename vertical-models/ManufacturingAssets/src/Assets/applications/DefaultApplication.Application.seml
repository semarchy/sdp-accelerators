                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.Product.action_sets.ProductActionSet.ImportAuthorProducts
            - _type: FolderAction
              _name: Errors
              label: Errors
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              image: images://default/folder-item-SDWE.png
              iconColor: md:grey
              appActions:
                - _type: BrowseBusinessViewAction
                  _name: FactoryErrors
                  businessView: Assets.entities.Factory.business_views.FactoryBusinessView
                  nbRecordsBadgeVisible: true
                  useSearchOnOpen: false
                  viewType: SAWE
                  nbRecordsBadgeBackgroundColor: md:red
                - _type: BrowseBusinessViewAction
                  _name: ProductionLineErrors
                  businessView: Assets.entities.ProductionLine.business_views.ProductionLineBusinessView
                  nbRecordsBadgeVisible: true
                  useSearchOnOpen: false
                  viewType: SAWE
                  nbRecordsBadgeBackgroundColor: md:red
                - _type: BrowseBusinessViewAction
                  _name: MachineErrors
                  businessView: Assets.entities.Machine.business_views.MachineBusinessView
                  nbRecordsBadgeVisible: true
                  useSearchOnOpen: false
                  viewType: SAWE
                  nbRecordsBadgeBackgroundColor: md:red
