                  image: images://default/folder-item-import.png
                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.LineType.action_sets.LineTypeActionSet.ImportAuthorLineTypes
                - _type: ImportDataAppAction
