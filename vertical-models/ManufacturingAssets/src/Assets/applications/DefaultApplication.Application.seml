                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.DigitalTwinStatus.action_sets.DigitalTwinStatusActionSet.ImportAuthorDigitalTwinStatuses
                - _type: ImportDataAppAction
