                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.CriticalityLevel.action_sets.CriticalityLevelActionSet.ImportAuthorCriticalityLevels
                - _type: ImportDataAppAction
                  _name: ImportMachineStatus
                  label: Import Machine Status
                  image: images://default/folder-item-import.png
                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.MachineStatus.action_sets.MachineStatusActionSet.ImportAuthorMachineStatuses
                - _type: ImportDataAppAction
                  _name: ImportProductionLineStatus
                  label: Import Production Line Status
                  image: images://default/folder-item-import.png
                  imageAlign: MIDDLE_CENTER
                  imageMode: FIT
                  importAction: Assets.entities.ProductionLineStatus.action_sets.ProductionLineStatusActionSet.ImportAuthorProductionLineStatuses
                - _type: ImportDataAppAction
                  _name: ImportLineType
