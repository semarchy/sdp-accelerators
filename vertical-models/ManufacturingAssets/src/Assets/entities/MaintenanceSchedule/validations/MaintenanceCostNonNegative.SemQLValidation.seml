_package: Assets.entities.MaintenanceSchedule.validations
_name: MaintenanceCostNonNegative
_type: SemQLValidation
entity: Assets.entities.MaintenanceSchedule.MaintenanceSchedule
label: Maintenance Cost Not Negative
condition: MaintenanceCost IS NULL OR MaintenanceCost >= 0
validationScope: PRE_CONSO
validationLabel: Maintenance cost must be greater than or equal to zero
