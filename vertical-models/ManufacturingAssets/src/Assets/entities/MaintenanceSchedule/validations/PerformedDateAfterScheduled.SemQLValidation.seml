_package: Assets.entities.MaintenanceSchedule.validations
_name: PerformedDateAfterScheduled
_type: SemQLValidation
entity: Assets.entities.MaintenanceSchedule.MaintenanceSchedule
label: Performed Date After Scheduled
condition: PerformedDate IS NULL OR ScheduledDate IS NULL OR PerformedDate >= ScheduledDate
validationScope: PRE_CONSO
validationLabel: Performed date must be on or after the scheduled date

