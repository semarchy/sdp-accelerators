_package: Assets.model_priv_grants
_name: BusinessUser
_type: ModelPrivGrant
roleName: BusinessUser
label: Business User
description: Business User with access to Product entity
entityPrivGrants:
  - _type: EntityPrivGrant
    entity: Assets.entities.Product.Product
    _name: Product
    checkoutAllowed: true
    createAllowed: true
    deleteAllowed: true
    exportAllowed: true
    removeAllowed: true
    defaultAccessType: READ_WRITE


  
  