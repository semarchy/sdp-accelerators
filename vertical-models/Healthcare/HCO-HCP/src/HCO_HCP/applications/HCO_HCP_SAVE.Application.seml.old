_package: HCO_HCP.applications
_name: HCO_HCP_SAVE
_type: Application
applicationTitle: Healthcare Demo
avatarImageUrl: images://HCO_HCP/healthcarelogo.png
coverImageUrl: images://HCO_HCP/healthcarelogo.png
favIcon: images://HCO_HCP/healthcarelogo.png
historyBrowsingEnabled: true
historyBrowsingRequiredRole: ""
logoUrl: images://HCO_HCP/healthcarelogo.png
visibility: VISIBLE
documentationConfig:
  documentationConfigDiagrams:
    - _name: Main
      _type: DocumentationConfigDiagram
      modelDiagram: HCO_HCP.model_diagrams.Main
      label: Main
    - _name: ICD
      _type: DocumentationConfigDiagram
      modelDiagram: HCO_HCP.model_diagrams.ICD
      label: ICD
label: Healthcare Demo
sortStrategy: POSITION
globalSearchConfig:
  displaySearchForDropdown: true
  sortBusinessViewsAlphabetically: true
  globalSearchBusinessViews:
    - _name: Products
      _type: GlobalSearchBoView
      viewType: GD
      businessView: HCO_HCP.entities.Products.business_views.Products
      maxResults: 5
      searchTypeConfig: HCO_HCP.entities.Products.business_views.Products.ProductsEO.TextConfig
    - _name: HCO
      _type: GlobalSearchBoView
      viewType: GD
      businessView: HCO_HCP.entities.HCO.business_views.HCO
      maxResults: 5
      searchTypeConfig: HCO_HCP.entities.HCO.business_views.HCO.HCOEO.TextConfig
    - _name: Member
      _type: GlobalSearchBoView
      viewType: GD
      businessView: HCO_HCP.entities.Member.business_views.Member
      maxResults: 5
      searchTypeConfig: HCO_HCP.entities.Member.business_views.Member.MemberEO.Encounters.Encounter.TextConfig
    - _name: HCP
      _type: GlobalSearchBoView
      viewType: GD
      businessView: HCO_HCP.entities.HCP.business_views.HCP
      maxResults: 5
      searchTypeConfig: HCO_HCP.entities.HCP.business_views.HCP.HCPEO.TextConfig
rootFolder:
  _name: Root
  icon: images://mdi/folder.svg
  label: Root Folder
  imageAlign: MIDDLE_CENTER
  imageMode: FIT
  _type: FolderAction
  appActions:
    - _name: TopActions
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      _type: FolderAction
      appActions:
        - _name: Inbox
          labelColor: md:green
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: MyTasksAction
          badgeVisible: true
        - _name: GlobalSearchConfig
          labelColor: md:green
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: GlobalSearchAction
        - _name: Entities
          label: Browse All Data
          labelColor: md:blue
          requiredRole: DataSteward
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseEntitiesFolderAction
          lineageEnabled: true
    - _name: BrowseData
      label: Browse Data
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      _type: FolderAction
      appActions:
        - _name: BrowseHCO
          label: Health Care Organizations
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCO.business_views.HCO
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseHCP
          label: Health Care Providers
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCP.business_views.HCP
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseTaxonomyGrouping
          icon: images://HCO_HCP/HealthcareTaxonomy.png
          label: Taxonomy Groupings
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.TaxonomyGrouping.business_views.TaxonomyGrouping
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseICD9CM
          icon: images://mdi/crosshairs-question.svg
          label: ICD-9-CM (diagnosis)
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.ICD9CM.business_views.ICD9CM
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseICD10CM
          icon: images://mdi/crosshairs-question.svg
          label: ICD-10-CM (diagnosis)
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.ICD10CM.business_views.ICD10CM
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: TherapeauticArea
          icon: images://HCO_HCP/HealthcareTherapeutic.png
          label: Therapeautic Areas
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.TherapeauticArea.business_views.TherapeauticArea
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: Products
          icon: images://HCO_HCP/Drugs.png
          label: Products
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Products.business_views.Products
          nbRecordsBadgeVisible: false
          businessViewIconOverride: images://mdi/pharmacy.svg
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseInsuranceCompany
          icon: images://mdi/domain.svg
          image: images://mdi/domain.svg
          label: Payers
          imageAlign: MIDDLE_CENTER
          imageMode: CONTAIN
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.InsuranceCompany.business_views.InsuranceCompany
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseMembers
          label: Members
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Member.business_views.Member
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
    - _name: ReferenceData
      label: Reference Data
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      _type: FolderAction
      appActions:
        - _name: BrowseAdministration
          icon: images://HCO_HCP/HealthcareAdmin.png
          iconColor: md:grey
          label: Administration
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Administration.business_views.Administration
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseStrength
          icon: images://HCO_HCP/Drugs.png
          label: Strength
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Strength.business_views.Strength
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseForm
          icon: images://HCO_HCP/Drugs.png
          label: Forms
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Form.business_views.Form
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseSponsor
          icon: images://HCO_HCP/HospitalBuilding.png
          label: Sponsors
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Sponsor.business_views.Sponsor
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseSpecialty
          icon: images://mdi/medical-bag.svg
          image: images://mdi/medical-bag.svg
          label: Specialties
          imageAlign: MIDDLE_CENTER
          imageMode: CONTAIN
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Specialty.business_views.Specialty
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: CoverageInfo
          icon: images://mdi/umbrella-outline.svg
          image: images://mdi/umbrella-outline.svg
          label: Coverage Info
          imageAlign: MIDDLE_CENTER
          imageMode: CONTAIN
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.Coverage.business_views.MemberCoverage
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseHCPSpeciality
          icon: images://mdi/link-variant.svg
          image: images://mdi/link-variant.svg
          imageAlign: MIDDLE_CENTER
          imageMode: CONTAIN
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCPSpecialty.business_views.HCPSpecialty
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
        - _name: BrowseICDMapping
          icon: images://HCO_HCP/ICDCodes.png
          label: ICDMappings
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.ICDMapping.business_views.ICDMapping
          nbRecordsBadgeVisible: false
          useSearchOnOpen: false
          viewType: GD
    - _name: DataStewardship
      label: Data Stewardship Actions
      labelColor: md:red
      requiredRole: DataSteward
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      _type: FolderAction
      appActions:
        - _name: UnconfirmedHCOs
          label: Unconfirmed HCOs
          labelColor: md:red
          requiredRole: DataSteward
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCO.business_views.ConfirmDuplicateHCO
          nbRecordsBadgeVisible: true
          useSearchOnOpen: false
          viewType: GD
        - _name: UnconfirmedHCPs
          label: Unconfirmed HCPs
          labelColor: md:red
          requiredRole: DataSteward
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCP.business_views.ConfirmDuplicateHCP
          nbRecordsBadgeVisible: true
          useSearchOnOpen: false
          viewType: GD
        - _name: HCOwithErrors
          label: Source HCOs with Errors
          labelColor: md:red
          requiredRole: DataSteward
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCO.business_views.HCO
          nbRecordsBadgeVisible: true
          businessViewLabelOverride: Source HCOs with Errors
          businessViewRootLabelOverride: Source HCOs with Errors
          businessViewRootPluralLabelOverride: Source HCOs with Errors
          useSearchOnOpen: false
          viewType: SDWE
        - _name: HCPwithErrors
          label: Source HCPs with Errors
          labelColor: md:red
          requiredRole: DataSteward
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCP.business_views.HCP
          nbRecordsBadgeVisible: true
          businessViewLabelOverride: Source HCPs with Errors
          businessViewRootLabelOverride: Source HCPs with Errors
          businessViewRootPluralLabelOverride: Source HCPs with Errors
          useSearchOnOpen: false
          viewType: SDWE
        - _name: DupHCO
          label: Review HCO Duplicates
          labelColor: md:red
          requiredRole: DataSteward
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCO.business_views.ReviewHCOSuggestions
          nbRecordsBadgeVisible: true
          businessViewLabelOverride: Review HCO Duplicates
          businessViewRootLabelOverride: Review HCO Duplicates
          businessViewRootPluralLabelOverride: Review HCO Duplicates
          useSearchOnOpen: false
          viewType: GD
        - _name: DupHCP
          icon: images://idh/NAICS_62.svg
          label: Review HCP Duplicates
          labelColor: md:red
          requiredRole: DataSteward
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: BrowseBusinessViewAction
          businessView: HCO_HCP.entities.HCP.business_views.ReviewHCPSuggestions
          nbRecordsBadgeVisible: true
          businessViewLabelOverride: Review HCP Duplicates
          businessViewRootLabelOverride: Review HCP Duplicates
          businessViewRootPluralLabelOverride: Review HCP Duplicates
          useSearchOnOpen: false
          viewType: GD
    - _name: Administration
      label: Administration Actions
      labelColor: md:red
      requiredRole: DataSteward
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      _type: FolderAction
      appActions:
        - _name: BulkLoading
          icon: images://mdi/settings-transfer-outline.svg
          iconColor: md:blue
          label: Bulk Loading
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          _type: FolderAction
          appActions:
            - _name: ImportAdministration
              label: Import Administrations
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Administration.action_sets.AdministrationActionSet.ImportAuthorAdministrations
            - _name: ImportForm
              label: Import Forms
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Form.action_sets.FormActionSet.ImportAuthorForms
            - _name: ImportHCO
              label: Import HCOs
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.HCO.action_sets.HCOActionSet.ImportAuthorHCOs
            - _name: ImportICD10CM
              label: Import ICD-10-CM
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.ICD10CM.action_sets.ICD10CMActionSet.ImportAuthorICD10CMs
            - _name: ImportICD9CM
              label: Import ICD-9-CM
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.ICD9CM.action_sets.ICD9CMActionSet.ImportAuthorICD9CMs
            - _name: ImportICDMapping
              label: Import ICD Mappings
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.ICDMapping.action_sets.ICDMappingActionSet.ImportAuthorICDMappings
            - _name: ImportInsuranceCompany
              label: Import Insurance Companies
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.InsuranceCompany.action_sets.InsuranceCompanyActionSet.ImportAuthorInsuranceCompanys
            - _name: ImportSpecialty
              label: Import Specialties
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Specialty.action_sets.SpecialtyActionSet.ImportAuthorSpecialtys
            - _name: ImportSponsor
              label: Import Sponsors
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Sponsor.action_sets.SponsorActionSet.ImportAuthorSponsors
            - _name: ImportTaxonomyGrouping
              label: Import Taxonomy Groupings
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.TaxonomyGrouping.action_sets.TaxonomyGroupingActionSet.ImportAuthorTaxonomyGroupings
            - _name: ImportTaxonomyClassification
              label: Import Taxonomy Classifications
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.TaxonomyClassification.action_sets.TaxonomyClassificationActionSet.ImportAuthorTaxonomyClassifications
            - _name: ImportTaxonomySpecialization
              label: Import Taxonomy Specializations
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.TaxonomySpecialization.action_sets.TaxonomySpecializationActionSet.ImportAuthorTaxonomySpecializations
            - _name: ImportTaxonomyClassificationSpecialization
              label: Import Taxonomy Classification Specializations
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.TaxonomyClassificationSpecialization.action_sets.TaxonomyClassificationSpecializationActionSet.ImportAuthorTaxonomyClassificationSpecializations
            - _name: ImportHCP
              label: Import HCPs
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.HCP.action_sets.HCPActionSet.ImportAuthorHCPs
            - _name: ImportHCPSpecialty
              label: Import HCP Specialties
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.HCPSpecialty.action_sets.HPCSpecialtyActionSet.ImportAuthorHPCSpecialtys
            - _name: ImportMember
              label: Import Members
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Member.action_sets.MemberActionSet.ImportAuthorMembers
            - _name: ImportCoverage
              label: Import Coverage
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Coverage.action_sets.MemberInsuranceCompanyActionSet.ImportAuthorMemberInsuranceCompanys
            - _name: ImportEncounter
              label: Import Encounters
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Encounter.action_sets.EncounterActionSet.ImportAuthorEncounters
            - _name: ImportTherapeauticArea
              label: Import Therapeautic Areas
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.TherapeauticArea.action_sets.TherapeauticAreaActionSet.ImportAuthorTherapeauticAreas
            - _name: ImportProducts
              label: Import Products
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Products.action_sets.ProductsActionSet.ImportAuthorProducts
            - _name: ImportStrength
              label: Import Strengths
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              _type: ImportDataAppAction
              importAction: HCO_HCP.entities.Strength.action_sets.StrengthActionSet.ImportAuthorStrengths
defaultAction: HCO_HCP.applications.HCO_HCP.Root.TopActions.GlobalSearchConfig
navDrawer:
  - _name: TopActions
    _type: FolderNavGroup
    dividerVisible: true
    labelVisible: false
    linkedFolder: HCO_HCP.applications.HCO_HCP.Root.TopActions
  - _name: BrowseData
    _type: FolderNavGroup
    dividerVisible: true
    labelVisible: true
    linkedFolder: HCO_HCP.applications.HCO_HCP.Root.BrowseData
  - _name: QuickActions
    _type: FolderNavGroup
    dividerVisible: true
    labelVisible: true
    linkedFolder: HCO_HCP.applications.HCO_HCP.Root.DataStewardship
  - _name: ReferenceData
    _type: FolderNavGroup
    dividerVisible: true
    labelVisible: true
    linkedFolder: HCO_HCP.applications.HCO_HCP.Root.ReferenceData
  - _name: BulkLoading
    _type: FolderNavGroup
    dividerVisible: true
    labelVisible: true
    linkedFolder: HCO_HCP.applications.HCO_HCP.Root.Administration
