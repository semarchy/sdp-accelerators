rootPluralLabel: ICD-10-CM (diagnosis)
useHierarchyOnOpen: true
label: ICD-10-CM (diagnosis)
rootBusinessViewEntity:
  _name: ICD10CMEO
  _type: BusinessViewEntity
  collection: HCO_HCP.entities.ICD10CM.collection_views.ICD10CMCollection
  displayRecordCount: ALWAYS
  enableUserDefinedSort: true
  entity: HCO_HCP.entities.ICD10CM.ICD10CM
