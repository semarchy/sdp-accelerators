    "name" : "first_name",
    "label" : "first name",
    "description" : null,
    "dataType" : "STRING"
  }, {
    "name" : "last_name",
    "label" : "last name",
    "description" : null,
    "dataType" : "STRING"
  }, {
    "name" : "postal_code",
    "label" : "postal code",
    "description" : null,
    "dataType" : "STRING"
  }, {
    "name" : "state",
    "label" : "state",
    "description" : null,
    "dataType" : "STRING"
  } ],
  "responseOutputs" : [ {
    "name" : "NPI",
    "label" : "NPI",
    "description" : null,
    "dataType" : "STRING",
    "valueSelector" : "$.results[0].number",
    "onAbsentValueBehavior" : "USE_DEFAULT_VALUE",
