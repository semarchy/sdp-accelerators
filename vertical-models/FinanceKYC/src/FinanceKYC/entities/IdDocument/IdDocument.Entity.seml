  - _name: DocumentNumber
    _type: EntityAttribute
    label: Document Number
    physicalName: DOCUMENT_NUMBER
    dataType: String
    length: 50
    mandatory: false

  - _name: IssueDate
    _type: EntityAttribute
    label: Issue Date
    physicalName: ISSUE_DATE
    dataType: Date
    mandatory: false

  - _name: ExpiryDate
    _type: EntityAttribute
    label: Expiry Date
    physicalName: EXPIRY_DATE
