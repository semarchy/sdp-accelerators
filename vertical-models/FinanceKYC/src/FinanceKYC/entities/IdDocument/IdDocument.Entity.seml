    mandatory: false

  - _name: IssuingCountry
    _type: EntityAttribute
    label: Issuing Country
    physicalName: ISSUING_COUNTRY
    dataType: String
    length: 30
    mandatory: false

  - _type: EntityAttribute
    _name: IssuingAuthority
    label: Issuing Authority
    physicalName: ISSUING_AUTHORITY
    dataType: String
    length: 50
