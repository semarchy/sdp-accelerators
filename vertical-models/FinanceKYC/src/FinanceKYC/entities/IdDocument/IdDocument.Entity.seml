iconUrl: images://mdi/book.svg
description: ""
documentation: ""
historizeGolden: false
historizeMaster: false
enableDelete: true

attributes:
  - _name: DocumentID
    _type: EntityAttribute
    label: Id Document ID
    physicalName: ID_DOCUMENT_ID
    dataType: String
    length: 36
    mandatory: true
    searchable: true
    documentation: Unique identifier for the document

  - _name: DocumentType
    _type: EntityAttribute
    label: Document Type
    physicalName: DOCUMENT_TYPE
    dataType: String
    length: 30
