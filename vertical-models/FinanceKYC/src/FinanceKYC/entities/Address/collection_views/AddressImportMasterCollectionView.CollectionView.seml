_package: FinanceKYC.entities.Address.collection_views
_type: CollectionView
_name: AddressImportMasterCollectionView

entity: FinanceKYC.entities.Address.Address
default: false
displayCard: FinanceKYC.entities.Address.display_cards.AddressDisplayCard

gridAllowed: false
gridColumns: 4
gridTextPosition: BOTTOM
gridTileHeight: 1:1
gridTileLines: 1

listAllowed: true
listItemLines: 1
listShowDisplayCardAvatar: false
listShowDivider: true

tableAllowed: true
tableDisplayCardColumnLabel: Address
tableRowLines: 1
tableShowDisplayCard: true

tableColumns:
