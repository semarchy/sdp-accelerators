_package: FinanceKYC.entities.IndividualPerson.collection_views
_type: CollectionView
_name: IndividualPersonCollectionView

entity: FinanceKYC.entities.IndividualPerson.IndividualPerson
default: true
displayCard: FinanceKYC.entities.IndividualPerson.display_cards.IndividualPersonDisplayCard

gridAllowed: false
gridColumns: 4
gridTextPosition: BOTTOM
gridTileHeight: 1:1
gridTileLines: 1

listAllowed: true
listItemLines: 1
listShowDisplayCardAvatar: false
listShowDivider: true

tableAllowed: true
tableDisplayCardColumnLabel: Individual Person
tableRowLines: 1
tableShowDisplayCard: true

tableColumns:
