  - _type: TextColumn
    _name: CountryOfIncorporation
    value: CountryOfIncorporation
    useCustomLabel: false
    dataType: STRING
    columnAlign: LEFT
    visibleByDefault: true
    documentationInterpreter: LITERAL

  - _type: TextColumn
    _name: TaxID
    value: TaxID
    useCustomLabel: false
    dataType: STRING
    columnAlign: LEFT
    visibleByDefault: true
    documentationInterpreter: LITERAL

  - _type: TextColumn
    _name: NormalizedTaxID
    value: NormalizedTaxID
    useCustomLabel: false
    dataType: STRING
    columnAlign: LEFT
    visibleByDefault: true
    documentationInterpreter: LITERAL

  - _type: TextColumn
    _name: Industry
    value: Industry
    useCustomLabel: false
