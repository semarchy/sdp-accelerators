    documentation: Type of employee, such as full-time, part-time, or contractor
    dataType: Organization.list_of_values.EmployeeType
    physicalName: EMPLOYEE_TYPE
    lovValidationScope: NONE
    mandatory: false
    mandatoryValidationLabel: ""
    valueSeparator: ","
  - _type: EntityAttribute
    _name: Address
    description: Employee address
    label: Address
    documentation: Employee address
    physicalName: ADD
    dataType: Organization.complex_types.SourceAddressType
    mandatory: false
primaryKey: Organization.entities.Employee.Employee.ID
sourceIdGeneration:
  mode: MANUAL
  startWith: 1
goldenIdGeneration:
  mode: SEQUENCE
  startWith: 10001
