    physicalName: SOURCE_EMAIL
    mandatory: true
    mandatoryValidationLabel: ""
    mandatoryValidationScope: PRE_CONSO
    valueSeparator: ","
    length: 128
  - _name: CleansedEmail
    _type: EntityAttribute
    label: Cleansed Email
    description: Employee email address after cleansing
    documentation: Employee email address after cleansing, standardized and validated
    dataType: String
    physicalName: CLEANSED_EMAIL
    mandatory: false
    mandatoryValidationLabel: ""
    valueSeparator: ","
    length: 128
  - _name: ValidEmailDomain
    _type: EntityAttribute
    label: Valid Email Domain
    description: Valid email domain flag
    documentation: Valid email domain flag, true if the email domain is valid
    dataType: String
    physicalName: VALID_EMAIL_DOMAIN
    mandatory: false
    mandatoryValidationLabel: ""
    valueSeparator: ","
    length: 128
  - _name: SourcePhone
    _type: EntityAttribute
    label: Source Phone
    description: Employee phone number
    documentation: Employee phone number before standardization
    dataType: String
    physicalName: SOURCE_PHONE
    mandatory: false
    mandatoryValidationLabel: ""
    valueSeparator: ","
    length: 128
  - _name: StandardizedPhone
    _type: EntityAttribute
    label: Standardized Phone
    description: Employee phone number after standardization
    documentation: Employee phone number after standardization, formatted to a
      standard pattern
    dataType: String
    physicalName: STANDARDIZED_PHONE
    mandatory: false
    mandatoryValidationLabel: ""
    valueSeparator: ","
    length: 128
  - _name: PhoneGeocodingData
    _type: EntityAttribute
    label: Phone Geocoding Data
    description: Geocoding data for the phone number
