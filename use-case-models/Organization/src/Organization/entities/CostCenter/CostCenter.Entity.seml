# This file defines the Cost Center entity in the Organization domain.
# It includes attributes such as CostCenterID and Name, along with their data types and properties.
# This entity is used to manage cost center information within the organization.
_package: Organization.entities.CostCenter
_type: Entity
_name: CostCenter
label: Cost Center
pluralLabel: Cost Center
entityType: BASIC
physicalTableName: COST_CENTER
iconUrl: images://hr-img-lib/cash-multiple.svg
