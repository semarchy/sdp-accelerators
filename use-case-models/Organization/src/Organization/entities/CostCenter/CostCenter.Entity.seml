    description: Unique identifier for the cost center.
    documentation: This attribute is the primary key for the Cost Center entity and is used to uniquely
    dataType: LongInteger
    precision: 38
    mandatory: true
    searchable: true
  - _type: EntityAttribute
    _name: Name
    label: Name
    description: Name of the cost center.
    documentation: This attribute holds the name of the cost center, which is used for display purposes
    physicalName: NAME
    dataType: String
    length: 255
    mandatory: true
    searchable: true
