                  - _name: Relation
                    label: Relation
                    value: >-
                      lookup
                      	STRING_AGG FDN_Role 
                      	FROM AccountContactRelations
                      	WHERE COALESCE(SEM_BOOLEAN_TO_CHAR(IsDirect), 'false') = 'true'
                      end
                    dataType: STRING
                    useCustomLabel: true
                    documentationInterpreter: LITERAL
                    visibleValue: ANY AccountContactRelations HAVE (FDN_Role IS NOT NULL)
                    visibleValueInterpreter: SEMQL
