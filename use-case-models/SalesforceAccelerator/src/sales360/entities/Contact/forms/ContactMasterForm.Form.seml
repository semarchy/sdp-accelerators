                        REPLACE(SEM_CONCAT(' ', '1',
                        MailingAddress.GeoStreetNumber,
                        MailingAddress.GeoStreetName, '

                        ', MailingAddress.GeoLocality, ',',
                        MailingAddress.GeoState , MailingAddress.GeoPostalCode ,
                        ',',  MailingAddress.GeoCountryShort ),' ,', ',')
                      linkDisplayTextValueInterpreter: SEMQL
                      linkSourceType: url
