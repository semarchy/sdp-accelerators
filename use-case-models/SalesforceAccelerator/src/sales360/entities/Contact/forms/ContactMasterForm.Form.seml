# This is the ContactMasterForm form used in the Salesforce Accelerator application.
# It defines the structure and fields for the Contact entity form,
# including various text fields and their properties
_package: sales360.entities.Contact.forms
_type: Form
_name: ContactMasterForm
entity: sales360.entities.Contact.Contact
default: false
