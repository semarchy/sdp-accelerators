                  - _name: MailingAddress
                    label: Mailing Address
                    value: SEM_CONCAT('','1', 'https://www.google.com/search?q=',
                      SEM_CONCAT('+','1',MailingAddress.GeoStreetNumber,
                      MailingAddress.GeoStreetName , MailingAddress.GeoLocality,
                      MailingAddress.GeoPostalCode, MailingAddress.GeoState,
