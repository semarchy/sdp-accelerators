    visibleByDefault: false
  - _type: TextColumn
    _name: Birthdate
    columnAlign: LEFT
    dataType: DATE
    useCustomLabel: false
    value: BirthDate
    visibleByDefault: false
  - _type: TextColumn
    _name: Description
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
