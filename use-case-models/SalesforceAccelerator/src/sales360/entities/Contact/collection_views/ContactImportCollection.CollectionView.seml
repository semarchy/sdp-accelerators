    value: MailingAddress.InpZipCode
    visibleByDefault: false
  - _type: TextColumn
    _name: MailingCountry
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: true
    label: MailingCountry
    value: MailingAddress.InpCountry
    visibleByDefault: false
  - _type: TextColumn
    _name: OtherStreet
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: true
    label: OtherStreet
    value: OtherAddress.InpAddressLine
    visibleByDefault: false
  - _type: TextColumn
    _name: OtherCity
    columnAlign: LEFT
