    useCustomLabel: true
    label: MailingStreet
    value: MailingAddress.InpAddressLine
    visibleByDefault: false
  - _type: TextColumn
    _name: MailingCity
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: true
