# This is the ContactImportCollection collection view used in the Salesforce Accelerator application.
# It defines how contacts are displayed in various formats such as grid, list, and table.
_package: sales360.entities.Contact.collection_views
_name: ContactImportCollection
_type: CollectionView
entity: sales360.entities.Contact.Contact
default: true
displayCard: sales360.entities.Contact.display_cards.ContactDisplayCard
tableAllowed: true
tableRowLines: 2
tableDisplayCardColumnLabel: Contact
tableShowDisplayCard: true
tableDisplayCardColumnWidth: 250
listAllowed: true
listItemLines: 2
listShowDisplayCardAvatar: true
listShowDivider: false
gridAllowed: false
gridColumns: 4
gridTileHeight: 1:1
gridTileLines: 1
gridTextPosition: BOTTOM
tableColumns:
  - _type: TextColumn
    _name: FirstName
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: FirstName
    visibleByDefault: false
  - _type: TextColumn
    _name: LastName
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: LastName
    visibleByDefault: false
  - _type: TextColumn
    _name: FullName
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: true
    label: Name
    value: FullName
    visibleByDefault: false
  - _type: TextColumn
    _name: Title
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: Title
    visibleByDefault: true
    defaultWidth: 300
  - _type: TextColumn
    _name: Department
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: Department
    visibleByDefault: true
    defaultWidth: 200

  - _type: TextColumn
    _name: Phone_StandardizedPhoneNumber
    columnAlign: LEFT
    dataType: STRING
    label: Phone
    useCustomLabel: true
    value: Phone.InpPhoneNumber
    visibleByDefault: true
  - _type: TextColumn
    _name: Email
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: SourceEmail
    visibleByDefault: true
  - _type: ReferenceColumn
    _name: FDN_LeadSource
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: FDN_LeadSource
    visibleByDefault: true
    displayCard: sales360.entities.LeadSource.display_cards.LeadSourceDisplayCard
    referencedEntity: sales360.entities.LeadSource.LeadSource
    componentProperties:
      displayType: chip
      displayTypeValueInterpreter: LITERAL
      useAvatarInChip: "1"
      useAvatarInChipValueInterpreter: LITERAL
  - _type: ReferenceColumn
    _name: ReportsToId
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: true
    label: ReportsToId
    value: FDN_ReportsToId
    visibleByDefault: false
    referencedEntity: sales360.entities.Contact.Contact
  - _type: ReferenceColumn
    _name: Salutation
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: FDN_Salutation
    visibleByDefault: false
    referencedEntity: sales360.entities.Salutation.Salutation
  - _type: TextColumn
    _name: HomePhone
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    label: HomePhone
    value: HomePhone
    visibleByDefault: false
  - _type: TextColumn
    _name: OtherPhone
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    label: OtherPhone
    value: OtherPhone
    visibleByDefault: false
  - _type: TextColumn
    _name: Fax
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: Fax
    visibleByDefault: false
  - _type: TextColumn
    _name: MailingStreet
    columnAlign: LEFT
