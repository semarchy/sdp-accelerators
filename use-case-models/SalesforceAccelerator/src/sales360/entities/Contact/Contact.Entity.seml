matcher:
  _name: SemlQLMatcherContact
  _type: SemQLMatcher
  autoConfirmGoldenThreshold: 95
  autoConfirmSingletons: true
  mergeThresholdMergingConfirmed: 89
  mergeThresholdMergingConfirmedWithNewMasters: 89
  mergeThresholdMergingConfirmedWithUnconfirmed: 89
  mergeThresholdMergingUnconfirmed: 89
  mergeThresholdMergingUnconfirmedWithNewMasters: 89
  mergeThresholdNewGroup: 89
  mergeThresholdRemergingPreviouslySplit: 100
  useMultiIterationGrouping: true
  useTransitiveMatchScore: true
  matchRules:
    - _type: SemQLMatchRule
      _name: NormalizedNameNickNameDOBEmail
      condition: |-
        /*** Normalized Name or nickname exact match ***/
        ( Record1.NormalizedFirstName = Record2.NormalizedFirstName
           or Record1.Nickname = Record2.Nickname
           or Record1.NormalizedFirstName = UPPER(Record2.Nickname)
           or UPPER(Record1.Nickname) =  Record2.NormalizedFirstName
        ) 
        and Record1.NormalizedLastName = Record2.NormalizedLastName


        /*** Date of birth exact match ***/
        and Record1.BirthDate = Record2.BirthDate 

        /*** Email exact match ***/
        and Record1.CleansedEmail = Record2.CleansedEmail
      label: Normalized Name Nick Name DOB Email
      documentation: Check a match on Names, Date of Birth and Email
      description: Check a match on Names, Date of Birth and Email
      matchScore: 98
      color: md:blue 900
      usingMatchOn: false
    - _type: SemQLMatchRule
      _name: NormalizedNameAddressDOBPhone
      condition: >-
        /*** Normalized Name or nickname exact match ***/

        ( Record1.NormalizedFirstName = Record2.NormalizedFirstName
           OR Record1.Nickname = Record2.Nickname 
           OR Record1.NormalizedFirstName = UPPER(Record2.Nickname) 
           OR UPPER(Record1.Nickname) =  Record2.NormalizedFirstName
        ) 

        AND Record1.NormalizedLastName = Record2.NormalizedLastName



        /*** Date of birth exact match ***/

        AND Record1.BirthDate= Record2.BirthDate


        /*** Address match ***/

        AND (COALESCE(Record1.Phone.StandardizedPhoneNumber,'') =
        COALESCE(Record2.Phone.StandardizedPhoneNumber, '')
            OR COALESCE(Record1.MobilePhone.StandardizedPhoneNumber,'') = COALESCE(Record2.MobilePhone.StandardizedPhoneNumber, '')  )
      label: Normalized Name Address DOB Phone
      documentation: Check a match on Names, Date of Birth and Address
      description: Check a match on Names, Date of Birth and Address
      matchScore: 96
      color: md:green 800
      usingMatchOn: false
    - _type: SemQLMatchRule
      _name: ExactEmail
      condition: Record1.CleansedEmail = Record2.CleansedEmail
      label: Exact Email
      documentation: Check extact email match
      description: Check extact email match
      matchScore: 68
      color: md:green 500
      usingMatchOn: false