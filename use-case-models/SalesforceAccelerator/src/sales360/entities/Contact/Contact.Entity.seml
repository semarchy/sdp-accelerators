# This file defines the Contact entity in the Salesforce Accelerator application.
# It includes attributes such as ContactID, Description, IndividualId, LastCUUpdateDate,
# Jigsaw, Fax, EmailBouncedDate, LastName, Nickname, along with their properties and validations.
# The entity is used to manage contact information within the application.
_name: Contact
_package: sales360.entities.Contact
_type: Entity
primaryKey: sales360.entities.Contact.Contact.ContactID
goldenIdGeneration:
  mode: SEQUENCE
  startWith: 1
sourceIdGeneration:
  mode: UUID
  
label: Contact
documentation: Represents a contact, which is a person associated with an account.
description: Represents a contact, which is a person associated with an account.
enableDelete: true
entityType: FUZZY_MATCHED
iconUrl: images://mdi/book.svg
pluralLabel: Contacts
historizeGolden: true
historizeMaster: true
physicalTableName: CONTACT
dataEntryAllowed: true
