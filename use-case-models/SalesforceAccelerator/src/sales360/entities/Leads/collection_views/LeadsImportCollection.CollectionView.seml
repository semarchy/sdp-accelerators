    value: Address.InpZipCode
    visibleByDefault: true

  - _type: TextColumn
    _name: Country
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: true
    label: Country
    value: Address.InpCountry
    visibleByDefault: true

  - _type: TextColumn
    _name: LeadStatus
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
    value: FDN_Status
    visibleByDefault: true
    referencedEntity: sales360.entities.LeadStatus.LeadStatus

  - _type: TextColumn
