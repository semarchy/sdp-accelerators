    useCustomLabel: true
    label: Salutation
    value: FDN_Salutation
    visibleByDefault: true
    referencedEntity: sales360.entities.Salutation.Salutation

  - _type: TextColumn
    _name: Name
    columnAlign: LEFT
    dataType: STRING
    useCustomLabel: false
