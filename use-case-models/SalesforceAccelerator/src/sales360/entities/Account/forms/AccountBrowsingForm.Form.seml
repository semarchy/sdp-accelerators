                      isVisibleValueInterpreter: LITERAL
              - _type: FormContainer
                _name: Container9
                layoutDirection: COLUMN
                content:
                  - _name: ShippingAddress
                    label: Shipping Address
                    value: >-
                      CASE WHEN
                      COALESCE(SEM_BOOLEAN_TO_CHAR(BusinessShippingAddressSame),
                      '') = 'false' 

                      THEN SEM_CONCAT(' ', '1', ShippingAddress.GeoStreetNumber,
                      ShippingAddress.GeoStreetName, '

                      ', ShippingAddress.GeoLocality, '

                      ',ShippingAddress.GeoState, SEM_CONCAT(', ','1',
                      ShippingAddress.GeoPostalCode,
                      ShippingAddress.GeoCountryShort)) 

                      ELSE '[Same as Billing Address]' END
                    dataType: STRING
                    useCustomLabel: true
                    documentationInterpreter: LITERAL
                    visibleValue: "1"
                    visibleValueInterpreter: LITERAL
                    _type: TextField
                    authoringMode: auto
                    authoringModeValueInterpreter: LITERAL
                    componentProperties:
                      textAlign: left
                      textAlignValueInterpreter: LITERAL
                      textTypography: body-1
                      textTypographyValueInterpreter: LITERAL
                      isMultiline: "1"
                      isMultilineValueInterpreter: LITERAL
                      multilineMaxLines: "3"
                      multilineMaxLinesValueInterpreter: LITERAL
                      multilineMinLines: "1"
                      multilineMinLinesValueInterpreter: LITERAL
                      isCharCounterVisible: "0"
                      isCharCounterVisibleValueInterpreter: LITERAL
                    labelProperties:
                      position: top
                      positionValueInterpreter: LITERAL
                      alignment: left
                      alignmentValueInterpreter: LITERAL
                      typography: caption
                      typographyValueInterpreter: LITERAL
                      isVisible: "1"
                      isVisibleValueInterpreter: LITERAL
                  - _name: GMapShipping
                    value: >-
                      '<!DOCTYPE html>

                      <html>
                        <head>   
                          <meta charset="utf-8">
                          <script src="https://maps.googleapis.com/maps/api/js?key=INSERT_YOUR_API_KEY"></script>
                          <script>
                      var address= "' || SEM_CONCAT(' ', '1',
                      ShippingAddress.GeoStreetNumber,
                      ShippingAddress.GeoStreetName,
                      ShippingAddress.GeoLocality, ShippingAddress.GeoState,
                      ShippingAddress.GeoCountry) || '"

                      var zoom = 14;

                      // mapType

                      // ROADMAP displays the normal, default 2D tiles of Google
                      Maps.

                      // SATELLITE displays photographic tiles.

                      // HYBRID displays a mix of photographic tiles and a tile
                      layer for prominent features (roads, city names).

                      // TERRAIN

                      var mapType = google.maps.MapTypeId.ROADMAP;

                      var useMarker = true;

                      var map;

                      function initialize() {   
                        var geocoder = new google.maps.Geocoder();
                        geocoder.geocode( { "address": address}, function(results, status) {
                          if (status == google.maps.GeocoderStatus.OK) {
                            displayMap(results[0].geometry.location);
                          }
                        });
                        window.onresize = resize;
                      }

                      function displayMap(latlng) {
                        var mapOptions = {
                          zoom: zoom,
                          center: latlng,
                          mapTypeId: mapType
                        }
                        map = new google.maps.Map(document.getElementById("map_canvas"), mapOptions);
                        if (useMarker) {
                          var marker = new google.maps.Marker({
                          map: map,
                          position: latlng,
                          opacity: 0.85,
                          title: "' 
                      || SEM_CONCAT('', '1', AccountName
                        , '" + String.fromCharCode(13) + "'
                        , ShippingAddress.GeoStreetNumber
                        , ' '
                        , ShippingAddress.GeoStreetName
                        , '" + String.fromCharCode(13) + "'
                        , ShippingAddress.GeoLocality
                        , ', '
                        , ShippingAddress.GeoState
                      )  

                      || '"
                          });
                        }
                        resize("");
                      }

                      function resize(e) {
                        var center = map.getCenter();
                        map.getDiv().style.height = window.innerHeight + "px";
                        map.getDiv().style.width =  window.innerWidth + "px";
                        google.maps.event.trigger(map, ''resize'');
                        map.setCenter(center);
                      }

                      google.maps.event.addDomListener(window, "load",
                      initialize);
                          </script>
                        </head>
                        <body style="margin:0px;">
                          <div id="map_canvas" style="margin:0px;"></div>
                        </body>
                      </html>'
                    dataType: STRING
                    useCustomLabel: false
                    documentationInterpreter: LITERAL
                    visibleValue: COALESCE(SEM_BOOLEAN_TO_CHAR(BusinessShippingAddressSame), '') =
                      'false'
                    visibleValueInterpreter: SEMQL
                    _type: ObjectField
                    authoringMode: auto
                    authoringModeValueInterpreter: LITERAL
                    componentProperties:
                      textTypography: body-1
                      textTypographyValueInterpreter: LITERAL
                      objectHeight: 300px
                      objectHeightValueInterpreter: LITERAL
                      sourceType: content
                      sourceTypeValueInterpreter: LITERAL
                    labelProperties:
                      position: left
                      positionValueInterpreter: LITERAL
                      alignment: right
