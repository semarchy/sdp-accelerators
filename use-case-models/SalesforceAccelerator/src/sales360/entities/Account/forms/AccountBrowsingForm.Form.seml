      - _type: FormSection
        _name: Address
        label: Address
        layoutDirection: COLUMN
        documentationInterpreter: LITERAL
        visibleValue: "1"
        visibleValueInterpreter: LITERAL
        content:
          - _type: FormContainer
            _name: Container7
            layoutDirection: ROW
            content:
              - _type: FormContainer
                _name: Container8
                layoutDirection: COLUMN
                content:
                  - _name: BillingAddress
                    label: Billing Address
                    value: >-
                      SEM_CONCAT(' ', '1', BillingAddress.GeoStreetNumber,
                      BillingAddress.GeoStreetName, '

                      ', BillingAddress.GeoLocality, '

                      ',BillingAddress.GeoState, SEM_CONCAT(', ','1',
                      BillingAddress.GeoPostalCode,
                      BillingAddress.GeoCountryShort))
                    dataType: STRING
                    useCustomLabel: true
