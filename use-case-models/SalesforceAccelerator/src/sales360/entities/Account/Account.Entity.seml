# This file defines the Account entity for the Salesforce Accelerator application.
# It includes attributes and properties for managing accounts and their details.
_name: Account
_package: sales360.entities.Account
_type: Entity
primaryKey: sales360.entities.Account.Account.AccountID
goldenIdGeneration:
  mode: SEQUENCE
  startWith: 1001
sourceIdGeneration:
  mode: UUID
label: Account
documentation: Represents an individual account, which is an organization (such
  as customers, competitors, and partners).
description: Represents an individual account, which is an organization (such as
  customers, competitors, and partners).
enableDelete: true
entityType: FUZZY_MATCHED
iconUrl: images://mdi/book.svg
pluralLabel: Accounts
historizeGolden: true
historizeMaster: true
physicalTableName: ACCOUNT
dataEntryAllowed: true
attributes:
  - _type: EntityAttribute
    _name: AccountID
    physicalName: ACCOUNT_ID
    dataType: LongInteger
    documentation: Unique identifier for the Account record
    description: Golden ID
    goldenAttribute: true
    i18ned: false
    label: Account ID
    mandatory: true
    length: 0
    multiValued: false
    precision: 38
    searchable: true
    valueSeparator: ","
  - _type: EntityAttribute
    _name: ValidEmailDomain
    physicalName: VALID_EMAIL_DOMAIN
    dataType: String
    goldenAttribute: true
    i18ned: false
    label: Valid Email Domain
    documentation: The domain part of the email address, used for email validation
    description:  Domain part of email address
    mandatory: false
    length: 128
    multiValued: false
    searchable: true
    valueSeparator: ","
  - _type: EntityAttribute
    _name: CleansedPersonEmail
    physicalName: CLEANSED_EMAIL
    dataType: String
    goldenAttribute: true
    i18ned: false
    label: Cleansed Email
    documentation: The cleansed email address of the person account
