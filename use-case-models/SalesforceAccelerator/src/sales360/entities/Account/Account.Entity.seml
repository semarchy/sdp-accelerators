matcher:
  _name: SemlQLMatcherAccount
  _type: SemQLMatcher
  autoConfirmGoldenThreshold: 91
  autoConfirmSingletons: true
  mergeThresholdMergingConfirmed: 85
  mergeThresholdMergingConfirmedWithNewMasters: 75
  mergeThresholdMergingConfirmedWithUnconfirmed: 75
  mergeThresholdMergingUnconfirmed: 75
  mergeThresholdMergingUnconfirmedWithNewMasters: 75
  mergeThresholdNewGroup: 75
  mergeThresholdRemergingPreviouslySplit: 100
  useMultiIterationGrouping: true
  useTransitiveMatchScore: true
  description: Account Match Rules
  matchRules:
    - _type: SemQLMatchRule
      _name: ExactNameEnrichedAddress
      condition: >-
        /* Match conditions for Business Accounts */

        COALESCE(SEM_BOOLEAN_TO_CHAR(Record1.IsPersonAccount),'false') =
        'false' 

        and COALESCE(SEM_BOOLEAN_TO_CHAR(Record2.IsPersonAccount),'false') =
        'false' 


        /* Exact match using name and geocoded address */

        and Record1.NormalizedAccountName = Record2.NormalizedAccountName 

        and (Record1.BillingAddress.GeoStreetNumber =
        Record2.BillingAddress.GeoStreetNumber 

        and Record1.BillingAddress.GeoStreetName =
        Record2.BillingAddress.GeoStreetName 

        and Record2.BillingAddress.GeoLocality =
        Record2.BillingAddress.GeoLocality ) 

        or

        (Record1.BillingAddress.GeoStreetNumber =
        Record2.BillingAddress.GeoStreetNumber 

        and Record1.BillingAddress.GeoStreetName =
        Record2.BillingAddress.GeoStreetName 

        and Record1.BillingAddress.GeoPostalCode =
        Record2.BillingAddress.GeoPostalCode )
      label: Exact Name Enriched Address
      matchScore: 98
      color: md:green 800
      documentation: Check exact match on the Account name and enriched address
      description: Check exact match on the Account name and enriched address
      usingMatchOn: false
    - _type: SemQLMatchRule
      _name: PhoneticNameMatch
      condition: >-
        /* Match conditions for Business Accounts */

        COALESCE(SEM_BOOLEAN_TO_CHAR(Record1.IsPersonAccount),'false') =
        'false' 

        and COALESCE(SEM_BOOLEAN_TO_CHAR(Record2.IsPersonAccount),'false') =
        'false' 


        and Record1.PhoneticAccountName = Record2.PhoneticAccountName 

        and Record1.BillingAddress.GeoPostalCode =
        Record2.BillingAddress.GeoPostalCode
      label: Phonetic Name Match
      documentation: Check Phonetcic Name and Postal Code
      description: Check Phonetcic Name and Postal Code
      matchScore: 90
      color: md:green 700
      usingMatchOn: false
    - _type: SemQLMatchRule
      _name: WebsiteAndParentMatch
      condition: >-
        /* Match conditions for Business Accounts */

        COALESCE(SEM_BOOLEAN_TO_CHAR(Record1.IsPersonAccount),'false') =
        'false' 

        and COALESCE(SEM_BOOLEAN_TO_CHAR(Record2.IsPersonAccount),'false') =
        'false' 


        and Record1.NormalizedWebsite = Record2.NormalizedWebsite

        and( Record1.ParentAccount.NormalizedAccountName =
        Record2.ParentAccount.NormalizedAccountName 
                 or( Record1.ParentAccount.NormalizedAccountName IS NULL and Record1.ParentAccount.NormalizedAccountName IS NULL ) 
                 )
      label: Website And Parent Match
      documentation: Check a match on website and Patrent account
      description: Check a match on website and Patrent account
      matchScore: 60
      color: md:green 300
      usingMatchOn: false