    description: Delete Campaign Member Status
    useCustomLabel: true
    waitDialogEnabled: false
    _type: DeleteAction
    deleteType: HARD_DELETE
    availableForGoldenData: true
    availableForMasterData: false
    multipleSelectionAllowed: true
  - _name: Export
    label: Export
    description: Export Campaign Member Status
    useCustomLabel: true
    waitDialogEnabled: false
