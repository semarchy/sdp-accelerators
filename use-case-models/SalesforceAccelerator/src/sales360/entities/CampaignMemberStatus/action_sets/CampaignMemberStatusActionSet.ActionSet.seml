    createdRecordType: GOLDEN
    createMultiple: false
    allowOtherPublishers: true
    stepper: sales360.entities.CampaignMemberStatus.steppers.AuthorCampaignMemberStatuses
  - _name: EditAuthorCampaignMemberStatuses
    label: Edit
    description: Edit Campaign Member Status
    useCustomLabel: true
    waitDialogEnabled: false
    _type: EditAction
    availableForGoldenData: true
    availableForMasterData: false
    availableForErrorData: false
