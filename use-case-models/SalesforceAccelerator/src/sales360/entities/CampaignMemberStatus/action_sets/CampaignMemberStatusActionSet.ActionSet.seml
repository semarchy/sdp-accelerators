# This is the CampaignMemberStatusActionSet action set used in the Salesforce Accelerator application.
# It defines various actions that can be performed on campaign member statuses, such as creating, editing,
# mass updating, copying, deleting, exporting, importing campaign member statuses, browsing graph,
# reviewing and confirming duplicates, merging or splitting duplicates, reviewing duplicate suggestions,
# and explaining records.
_name: CampaignMemberStatusActionSet
_package: sales360.entities.CampaignMemberStatus.action_sets
_type: ActionSet
entity: sales360.entities.CampaignMemberStatus.CampaignMemberStatus
label: Campaign Member Status Action Set
description: Action Set for Campaign Member Status entity in Salesforce Accelerator
defaultActionSet: true
actions:
  - _name: CreateAuthorCampaignMemberStatuses
    label: Create
    useCustomLabel: true
    waitDialogEnabled: false
