    description: Unique identifier for the opportunity type
    mandatory: true
    length: 128
    multiValued: false
    searchable: true
    valueSeparator: ","
  - _type: EntityAttribute
    _name: OpportunityValue
    physicalName: OPPORTUNITY_VALUE
    dataType: String
    goldenAttribute: true
    i18ned: false
    label: Opportunity Value
