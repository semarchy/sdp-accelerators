historizeMaster: false
physicalTableName: OPPORTUNITY_TYPE
dataEntryAllowed: true
attributes:
  - _type: EntityAttribute
    _name: OpportunityTypeID
    physicalName: OPPORTUNITY_TYPE_ID
    dataType: String
    goldenAttribute: true
    i18ned: false
    label: Opportunity Type ID
