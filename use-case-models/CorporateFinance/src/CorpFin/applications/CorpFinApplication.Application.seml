_package: CorpFin.applications
_type: Application
_name: CorpFinApplication
label: Corporate Finance
visibility: VISIBLE
applicationTitle: Corporate Finance MDM

avatarImageUrl: images://corpfin/CoA-MDM-icon.svg
logoUrl: images://corpfin/CoA-MDM-icon.svg
coverImageUrl: images://corpfin/CoA-MDM-icon.svg
favIcon: images://corpfin/CoA-MDM-icon.svg
sortStrategy: POSITION
historyBrowsingEnabled: false
historyBrowsingRequiredRole: ""

defaultAction: CorpFin.applications.CorpFinApplication.Root.GlobalSearch

documentationConfig:
  documentation: ""
  documentationConfigDiagrams:
    - _name: DiagramCoA
      _type: DocumentationConfigDiagram
      modelDiagram: CorpFin.model_diagrams.CorpFinCoA
      label: CoA Diagram
    - _name: DiagramCounterparty
      _type: DocumentationConfigDiagram
      modelDiagram: CorpFin.model_diagrams.CorpFinCounterParty
      label: Counterparty Diagram
    - _name: DiagramOrgEntities
      _type: DocumentationConfigDiagram
      modelDiagram: CorpFin.model_diagrams.CorpFinOrgEntities
      label: Organization Entities Diagram
    - _name: DiagramRefData
      _type: DocumentationConfigDiagram
      modelDiagram: CorpFin.model_diagrams.CorpFinRefData
      label: Reference Data Diagram
    - _name: DiagramSuperModel
      _type: DocumentationConfigDiagram
      modelDiagram: CorpFin.model_diagrams.CorpFin
      label: SuperModel Diagram

globalSearchConfig:
  displaySearchForDropdown: true
  sortBusinessViewsAlphabetically: false
  globalSearchBusinessViews:
    - _type: GlobalSearchBoView
      _name: Accounts
      label: Accounts
      viewType: GD
      businessView: CorpFin.entities.Account.business_views.AccountBusinessView
      searchTypeConfig: CorpFin.entities.Account.business_views.AccountBusinessView.Account.TextConfig
      maxResults: 5
    - _type: GlobalSearchBoView
      _name: ChartOfAccounts
      label: Chart of Accounts
      viewType: GD
      businessView: CorpFin.entities.ChartOfAccounts.business_views.ChartOfAccountsBusinessView
      searchTypeConfig: CorpFin.entities.ChartOfAccounts.business_views.ChartOfAccountsBusinessView.ChartOfAccounts.TextConfig
      maxResults: 5
    - _type: GlobalSearchBoView
      _name: Contacts
      label: Contacts
      viewType: GD
      businessView: CorpFin.entities.ContactInformation.business_views.ContactInformationBusinessView
      searchTypeConfig: CorpFin.entities.ContactInformation.business_views.ContactInformationBusinessView.ContactInformation.TextConfig
      maxResults: 5
    - _type: GlobalSearchBoView
      _name: Coounterparties
      label: Counterparties
      viewType: GD
      businessView: CorpFin.entities.Counterparty.business_views.CounterpartyBusinessView
      searchTypeConfig: CorpFin.entities.Counterparty.business_views.CounterpartyBusinessView.Counterparty.TextConfig
      maxResults: 5
    - _type: GlobalSearchBoView
      _name: Customers
      label: Customers
      viewType: GD
      businessView: CorpFin.entities.Customer.business_views.CustomerBusinessView
      searchTypeConfig: CorpFin.entities.Customer.business_views.CustomerBusinessView.Customer.TextConfig
      maxResults: 5
    - _type: GlobalSearchBoView
      _name: OrgEntities
      label: Org Entities
      viewType: GD
      businessView: CorpFin.entities.OrgUnit.business_views.OrgUnitBusinessView
      searchTypeConfig: CorpFin.entities.OrgUnit.business_views.OrgUnitBusinessView.OrgUnit.TextConfig
      maxResults: 5
    - _type: GlobalSearchBoView
      _name: Suppliers
      label: Suppliers
      viewType: GD
      businessView: CorpFin.entities.Supplier.business_views.SupplierBusinessView
      searchTypeConfig: CorpFin.entities.Supplier.business_views.SupplierBusinessView.Supplier.TextConfig
      maxResults: 5

navDrawer:
  - _type: NavigationGroup
    _name: RootFolder
    label : Root Folder
    dividerVisible: false
    labelVisible: false
    
    actions:
      - appAction: CorpFin.applications.CorpFinApplication.Root.MyTasks
      - appAction: CorpFin.applications.CorpFinApplication.Root.GlobalSearch
  
  - _type: FolderNavGroup
    _name: Organization
    dividerVisible: true
    labelVisible: true
    linkedFolder: CorpFin.applications.CorpFinApplication.Root.Organization
  
  - _type: FolderNavGroup
    _name: CoAs
    dividerVisible: true
    labelVisible: true
    linkedFolder: CorpFin.applications.CorpFinApplication.Root.CoAs
  
  - _type: FolderNavGroup
    _name: Counterparties
    dividerVisible: true
    labelVisible: true
    linkedFolder: CorpFin.applications.CorpFinApplication.Root.Counterparties
  
  - _type: FolderNavGroup
    _name: Stewardship
    dividerVisible: true
    labelVisible: true
    linkedFolder: CorpFin.applications.CorpFinApplication.Root.Stewardship

  - _type: FolderNavGroup
    _name: Admin
    dividerVisible: true
    labelVisible: true
    linkedFolder: CorpFin.applications.CorpFinApplication.Root.Admin

rootFolder:
  _type: FolderAction
  _name: Root
  label: Root Folder
  image: images://mdi/folder.svg
  imageAlign: MIDDLE_CENTER
  imageMode: FIT
  
  appActions:
    - _type: MyTasksAction
      _name: MyTasks
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      badgeVisible: true
      iconColor: '#ff0000ff'

    - _type: GlobalSearchAction
      _name: GlobalSearch
      imageAlign: MIDDLE_CENTER
      imageMode: FIT

    - _type: FolderAction
      _name: Organization
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      label: Our Organizations
      
      appActions:
        - _type: BrowseBusinessViewAction
          _name: BrowseOrgHierarchies
          businessView: CorpFin.entities.OrgHierarchy.business_views.OrgHierarchyBusinessView
          label: Browse Hierarchies
          labelColor: md:blue
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse OrgHierarchy records
          image: images://mdi/file-tree.svg
          iconColor: md:blue
          
        - _type: FolderAction
          _name: OrgStructures
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          label: Org Structures
          labelColor: md:blue
          # description: Access Business Views
          image: images://mdi/folder.svg
          iconColor: md:blue
          appActions:           
            - _type: BrowseBusinessViewAction
              _name: BrowseOrgHierarchy
              businessView: CorpFin.entities.OrgHierarchy.business_views.OrgHierarchyBusinessView
              label: Org Hierarchies
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              # description: Browse Org Hierarchy records
              image: images://mdi/file-tree.svg
              iconColor: md:blue

            - _type: BrowseBusinessViewAction
              _name: BrowseOrgUnits
              businessView: CorpFin.entities.OrgUnit.business_views.OrgUnitBusinessView
              label: Org Units
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              # description: Browse Org Unit records
              image: images://mdi/domain.svg
              iconColor: md:blue     
              
            - _type: BrowseBusinessViewAction
              _name: BrowseOrgHierarchyNode
              businessView: CorpFin.entities.OrgHierarchyNode.business_views.OrgHierarchyNodeBusinessView
              label: Org Hierarchy Nodes
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              # description: Browse Org Hierarchy Node records
              image: images://mdi/link-variant.svg
              iconColor: md:blue     
              
            - _type: BrowseBusinessViewAction
              _name: BrowseOrgUnitCoAAssignment
              businessView: CorpFin.entities.OrgUnitCoAAssignment.business_views.OrgUnitCoAAssignmentBusinessView
              label: Org Unit CoA Assignments
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              # description: Browse Org Unit CoA Assignment records
              image: images://mdi/account-details.svg
              iconColor: md:blue     
              
            - _type: BrowseBusinessViewAction
              _name: BrowseOrgUnitMappingCoverage
              businessView: CorpFin.entities.OrgUnitMappingCoverage.business_views.OrgUnitMappingCoverageBusinessView
              label: Org Unit Mapping Coverages
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              # description: Browse Org Unit Mapping Coverage records
              image: images://mdi/clipboard-edit-outline.svg
              iconColor: md:blue   
            
            - _type: BrowseBusinessViewAction
              _name: BrowseOrgUnitTypes
              businessView: CorpFin.entities.OrgUnitType.business_views.OrgUnitTypeBusinessView
              label: Org Unit Types
              imageAlign: MIDDLE_CENTER
              imageMode: FIT
              nbRecordsBadgeVisible: false
              # description: Browse Org Unit Type records
              image: images://mdi/move-resize-variant.svg
              iconColor: md:blue        

    - _type: FolderAction
      _name: CoAs
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      label: Charts of Accounts
      appActions:
        - _type: BrowseBusinessViewAction
          _name: BrowseChartsOfAccounts
