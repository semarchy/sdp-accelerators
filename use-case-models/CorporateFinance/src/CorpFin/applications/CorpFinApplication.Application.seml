        - _type: OpenDashboardAction
          _name: CounterpartyMetrics
          label: Dashboard
          dashboard: CounterpartyMetrics
          dashboardApplication: CorpFinDashboard
          iconColor: md:green
          labelColor: md:green


    - _type: FolderAction
      _name: Stewardship
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      label: Data Stewardship

      appActions:
        - _name: ConfirmMatchesCounterparty
          _type: BrowseBusinessViewAction
          label: "Counterparties: Confirm Matches"
          businessView: CorpFin.entities.Counterparty.business_views.CounterpartyConfirmMatches
          nbRecordsBadgeVisible: true
          icon: images://mdi/map-marker-check-outline.svg
          iconColor: md:grey
          labelColor: md:grey
          viewType: GD

        - _name: SuggestedMatchesCounterparty
