          nbRecordsBadgeVisible: true
          icon: images://mdi/map-marker-alert-outline.svg
          iconColor: md:grey
          labelColor: md:grey
          viewType: GD    

        - _name: Errors
          _type: FolderAction
          icon: images://mdi/alert-octagon.svg
          iconColor: md:red
          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          label: Error Management
          labelColor: md:grey

