          imageAlign: MIDDLE_CENTER
          imageMode: FIT
          nbRecordsBadgeVisible: false
          description: Browse CoAs & Accounts
          image: images://mdi/file-tree.svg
          iconColor: md:orange
          
          
        - _type: FolderAction
          _name: AccountMappings
          imageAlign: MIDDLE_CENTER
