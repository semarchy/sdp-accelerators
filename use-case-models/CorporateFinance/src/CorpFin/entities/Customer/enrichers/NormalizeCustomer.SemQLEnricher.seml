_package: CorpFin.entities.Customer.enrichers
_name: NormalizeCustomer
_type: SemQLEnricher
entity: CorpFin.entities.Customer.Customer
label: Normalize Customer Payment Terms
enricherExecutionScope: PRE_CONSO

semQlEnricherExpressions:
  - attributeName: NormalizedPaymentTerms
    expression: "RTRIM(LTRIM(UPPER(PaymentTerms)))"
