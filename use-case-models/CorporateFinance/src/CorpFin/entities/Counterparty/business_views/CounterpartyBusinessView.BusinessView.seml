_package: CorpFin.entities.Counterparty.business_views
_type: BusinessView
_name: CounterpartyBusinessView

entity: CorpFin.entities.Counterparty.Counterparty
rootLabel: Counterparties
rootPluralLabel: Counterparties
rootIconUrl: images://mdi/hexagon.svg
displayRootNodeAs: ICON_LABEL
label: Counterparties
        
enableHierarchyView: false
useHierarchyOnOpen: false

rootBusinessViewEntity:
  _type: BusinessViewEntity
  _name: Counterparty
  entity: CorpFin.entities.Counterparty.Counterparty
  actionSet: CorpFin.entities.Counterparty.action_sets.CounterpartyActionSet
  collection: CorpFin.entities.Counterparty.collection_views.CounterpartyCollectionView
  form: CorpFin.entities.Counterparty.forms.CounterpartyForm
  displayCard: CorpFin.entities.Counterparty.display_cards.CounterpartyDisplayCard
  outlineVisible: false
  displayRecordCount: ALWAYS

  businessEntitySearchConfigs:
    - _name: TextConfig
      _type: BusinessEntitySearchTypeConfig
      searchType: TEXT
    - _name: FormConfig
      _type: BusinessEntitySearchTypeConfig
      searchType: BY_FORM
    - _name: AdvancedConfig
      _type: BusinessEntitySearchTypeConfig
      searchType: ADVANCED
    - _name: SemqlConfig
      _type: BusinessEntitySearchTypeConfig
      searchType: SEMQL

  overrideDefaultSort: false
  enableUserDefinedSort: true
  listAllowed: true
  tableAllowed: true
  gridAllowed: true

  transitions:
    - _name: MasterRecords
      _type: BusinessViewTransition
      transitionType: FULLY_QUALIFIED
      displayFormTabAs: ICON_LABEL
      enableHierarchyInterpreter: LITERAL
      expandHierarchyByDefault: false
      filter: 1 = 1
      iconUrl: images://mdi/puzzle.svg
      transitionPath: MasterRecords
      useCustomLabel: false

      businessViewEntity:
        _name: CounterpartyMaster
        _type: BusinessViewEntity

        businessEntitySearchConfigs:
          - _name: TextConfig
            _type: BusinessEntitySearchTypeConfig
            searchType: TEXT
          - _name: FormConfig
            _type: BusinessEntitySearchTypeConfig
            searchType: BY_FORM
          - _name: AdvancedConfig
            _type: BusinessEntitySearchTypeConfig
            searchType: ADVANCED
          - _name: SemqlConfig
            _type: BusinessEntitySearchTypeConfig
            searchType: SEMQL

        collection: CorpFin.entities.Counterparty.collection_views.CounterpartyBrowseMasterCollectionView
        displayRecordCount: ALWAYS
        enableUserDefinedSort: true
        entity: CorpFin.entities.Counterparty.Counterparty
        form: CorpFin.entities.Counterparty.forms.CounterpartyForm
        displayCard: CorpFin.entities.Counterparty.display_cards.CounterpartyDisplayCard
        gridAllowed: true
        listAllowed: true
        outlineVisible: false
        overrideDefaultSort: false
        # sortExpression: ''
        tableAllowed: true

    - _name: ToContactInfo
      _type: BusinessViewTransition
      transitionType: FULLY_QUALIFIED
      displayFormTabAs: ICON_LABEL
      displayTransitionNodeAs: ICON_LABEL
      iconUrl: images://mdi/badge-account-horizontal-outline.svg
      useCustomLabel: false

      transitionPath: contactInformation
      visibleInFormTabCondition: any contactInformation has (1 = 1)
      
      businessViewEntity:
        _name: ToContactInfo
        _type: BusinessViewEntity

        collection: CorpFin.entities.ContactInformation.collection_views.ContactInformationCollectionView
        displayRecordCount: ALWAYS
        enableUserDefinedSort: true
        entity: CorpFin.entities.ContactInformation.ContactInformation
        form: CorpFin.entities.ContactInformation.forms.ContactInformationForm
        displayCard: CorpFin.entities.ContactInformation.display_cards.ContactInformationDisplayCard
        gridAllowed: true
        listAllowed: true
        outlineVisible: false
        overrideDefaultSort: false
        # sortExpression: ''
        tableAllowed: true

    - _name: ToRiskProfile
      _type: BusinessViewTransition
      transitionType: FULLY_QUALIFIED
      displayFormTabAs: ICON_LABEL
      displayTransitionNodeAs: ICON_LABEL
      iconUrl: images://mdi/shield-account.svg
      useCustomLabel: false

      transitionPath: riskComplianceProfile
      visibleInFormTabCondition: any riskComplianceProfile has (1 = 1)
      
      businessViewEntity:
        _name: ToRiskProfile
        _type: BusinessViewEntity

        collection: CorpFin.entities.RiskComplianceProfile.collection_views.RiskComplianceProfileCollectionView
        displayRecordCount: ALWAYS
        enableUserDefinedSort: true
        entity: CorpFin.entities.RiskComplianceProfile.RiskComplianceProfile
        form: CorpFin.entities.RiskComplianceProfile.forms.RiskComplianceProfileForm
        displayCard: CorpFin.entities.RiskComplianceProfile.display_cards.RiskComplianceProfileDisplayCard
        gridAllowed: true
        listAllowed: true
        outlineVisible: false
        overrideDefaultSort: false
        # sortExpression: ''
        tableAllowed: true

    - _name: ToAddress
      _type: BusinessViewTransition
      transitionType: FULLY_QUALIFIED
      displayFormTabAs: ICON_LABEL
      displayTransitionNodeAs: ICON_LABEL
      iconUrl: images://mdi/map-marker.svg
      useCustomLabel: false

      transitionPath: counterpartyAddress
      visibleInFormTabCondition: any counterpartyAddress has (1 = 1)
      
      businessViewEntity:
