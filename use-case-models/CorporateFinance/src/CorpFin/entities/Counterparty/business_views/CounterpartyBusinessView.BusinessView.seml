      transitionType: FULLY_QUALIFIED
      displayFormTabAs: ICON_LABEL
      displayTransitionNodeAs: ICON_LABEL
      iconUrl: images://mdi/truck.svg
      label: Supplier Details
      pluralLabel: Supplier Details
      useCustomLabel: true

      transitionPath: supplier
