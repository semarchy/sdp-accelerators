_package: CorpFin.entities.Supplier.enrichers
_name: NormalizeSupplier
_type: SemQLEnricher
entity: CorpFin.entities.Supplier.Supplier
label: Normalize Supplier Payment Terms
enricherExecutionScope: PRE_CONSO

semQlEnricherExpressions:
  - attributeName: NormalizedPaymentTerms
    expression: "RTRIM(LTRIM(UPPER(PaymentTerms)))"
