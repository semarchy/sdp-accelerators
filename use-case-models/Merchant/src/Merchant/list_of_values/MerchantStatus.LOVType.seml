# Description: List-of-values for `MerchantStatus`.
# Contains lifecycle/status codes for merchant records (e.g., Active, Suspended).
# Role: Drives status-based UI behavior and reporting for merchants.
_package: Merchant.list_of_values
_name: MerchantStatus
_type: LOVType
label: Status
length: 50

lovValues:
  - label: Active
    code: Active 
  - label: Suspended
    code: Suspended
  - label: Terminated
    code: Terminated
  - label: Onboarded
    code: Onboarded