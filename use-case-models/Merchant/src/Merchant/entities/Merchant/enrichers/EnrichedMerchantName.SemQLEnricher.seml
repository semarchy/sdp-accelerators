_package: Merchant.entities.Merchant.enrichers
_name: EnrichedMerchantName
_type: SemQLEnricher
entity: Merchant.entities.Merchant.Merchant
label: Enriched Merchant Name
description: Enricher to populate the Enriched Merchant Name attribute based on the original Merchant
enricherExecutionScope: PRE_CONSO
semQlEnricherExpressions: 
  - attributeName: EnrichedMerchantName
    expression: UPPER(MerchantName)
