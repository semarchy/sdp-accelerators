_package: Merchant.entities.Party.enrichers
_name: NormalizedName
_type: SemQLEnricher
entity: Merchant.entities.Party.Party
label: Normalized Name
description: Enricher to populate NormalizedName based on DisplayName using SemQL expression.
enricherExecutionScope: PRE_CONSO
semQlEnricherExpressions: 
  - attributeName: NormalizedName
    expression: UPPER(DisplayName)
