# Description: Reference linking `PartyContact` to `Party`.
# Contains navigation, foreign attribute and validation for contactâ†’party relationship.
# Role: Associates contact records with their parent party in the model.
_package: Merchant.references
_name: PartyHasContact
_type: Reference
