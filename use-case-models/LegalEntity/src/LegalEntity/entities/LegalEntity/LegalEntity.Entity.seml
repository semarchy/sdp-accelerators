    documentation: The address of the legal entity with geocoding information, such as latitude and longitude.
  - _name: NewInTY22
    dataType: LegalEntity.list_of_values.YesNo
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    lovValidationScope: PRE_CONSO
    multiValued: false
    searchable: true
    physicalName: NEW_IN_TY22
    label: New In TY22
    description: Indicates if the legal entity is new in tax year 2022.
    documentation: Yes/No flag indicating whether the legal entity was created or added in tax year 2022.
  - _name: FinalInTY22
    dataType: LegalEntity.list_of_values.YesNo
    _type: EntityAttribute
    length: 128
    lovValidationScope: PRE_CONSO
    mandatory: false
    i18ned: false
    multiValued: false
    searchable: true
    physicalName: FINAL_IN_TY22
    label: Final In TY22
