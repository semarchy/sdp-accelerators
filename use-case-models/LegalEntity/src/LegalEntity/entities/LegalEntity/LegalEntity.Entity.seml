  - _name: ChainID
    dataType: String
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 5
    multiValued: false
    searchable: true
    physicalName: CHAIN_ID
    label: Chain ID
    description: The chain ID for the legal entity.
    documentation: The unique chain identifier used for linking and integration purposes.
entityType: FUZZY_MATCHED
historizeGolden: false
historizeMaster: false
physicalTableName: LEGAL_ENTITY
matcher:
  _type: SemQLMatcher
  _name: LegalEntityMatcher
  autoConfirmGoldenThreshold: 99
  autoConfirmSingletons: true
  matchRules:
    - _name: ExactEIN
      label: ExactEIN
      _type: SemQLMatchRule
      condition: "Record1.USFEIN = Record2.USFEIN"
      matchScore: 100
      usingMatchOn: false
    - _name: ExactNameAddress
      label: ExactNameAddress
      _type: SemQLMatchRule
      condition: "Record1.NormalizedName  = Record2.NormalizedName AND Record1.InputAddress.AddressLine = Record2.InputAddress.AddressLine AND Record1.InputAddress.City = Record2.InputAddress.City AND Record1.InputAddress.State = Record2.InputAddress.State AND Record1.InputAddress.Country = Record2.InputAddress.Country AND Record1.InputAddress.ZipCode = Record2.InputAddress.ZipCode"
      matchScore: 90
      usingMatchOn: false
    - _name: ExactName
      label: ExactName
      _type: SemQLMatchRule
      condition: "Record1.NormalizedName  = Record2.NormalizedName" 
      matchScore: 75
      usingMatchOn: false
  mergeThresholdMergingConfirmed: 85
  mergeThresholdMergingConfirmedWithNewMasters: 85
  mergeThresholdMergingConfirmedWithUnconfirmed: 85
  mergeThresholdMergingUnconfirmed: 85
  mergeThresholdMergingUnconfirmedWithNewMasters: 85
  mergeThresholdNewGroup: 85
  mergeThresholdRemergingPreviouslySplit: 85
  useMultiIterationGrouping: true
  useTransitiveMatchScore: true
primaryKey: LegalEntity.entities.LegalEntity.LegalEntity.ID

sourceIdGeneration:
  mode: MANUAL
goldenIdGeneration:
  mode: SEQUENCE
  startWith: 1200