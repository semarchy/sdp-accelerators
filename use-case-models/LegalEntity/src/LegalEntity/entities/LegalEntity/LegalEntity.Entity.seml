    documentation: Yes/No flag indicating whether the legal entity was finalized or closed in tax year 2022.
  - _name: K1DueJune30
    dataType: LegalEntity.list_of_values.YesNo
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    lovValidationScope: PRE_CONSO
    multiValued: false
    searchable: true
    physicalName: K1_DUE_JUNE_30
    label: K1 Due June 30
    description: Indicates if the K-1 form is due by June 30 for the legal entity.
    documentation: Yes/No flag indicating whether the K-1 tax form is due by June 30 for the legal entity.
  - _name: FromADVPF
    dataType: LegalEntity.list_of_values.YesNo
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    lovValidationScope: PRE_CONSO
    multiValued: false
    searchable: true
    physicalName: FROM_ADV_PF
    label: From Adv PF
    description: Indicates if the legal entity is from ADV PF.
    documentation: Yes/No flag indicating whether the legal entity originated from ADV PF.
  - _name: ENableTaxSoftware
    dataType: LegalEntity.list_of_values.YesNo
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    lovValidationScope: PRE_CONSO
    multiValued: false
    searchable: true
    physicalName: ENABLE_TAX_SOFTWARE
    label: Enable Tax Software
    description: Indicates if tax software is enabled for the legal entity.
    documentation: Yes/No flag indicating whether tax software is enabled for the legal entity.
  - _name: Website
    dataType: String
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    multiValued: false
    searchable: true
    physicalName: WEBSITE
    label: Website
