## This file defines the LegalEntity entity for the Legal Entity application.
## It includes attributes and properties for managing legal entities and their details.
_package: LegalEntity.entities.LegalEntity
_type: Entity
_name: LegalEntity
pluralLabel: Legal Entities
label: Legal Entity
iconUrl: images://le-img-lib/office-building.svg
description: This entity represents a legal entity in the Legal Entity application. It is used to store and manage organizations, companies, or other formal entities for business activities, compliance, and reporting.
documentation: The LegalEntity entity defines the structure for storing legal entity records, including names, addresses, identifiers, and business attributes. It supports business logic, reporting, compliance, and integration with external systems. In private equity, a legal entity is a distinct organization established to conduct business and hold assets, often structured as a limited partnership or LLC.
enableDelete: true
attributes: 
  - _name: ID
    dataType: LongInteger
    _type: EntityAttribute
    mandatory: true
    mandatoryValidationScope: PRE_CONSO
    i18ned: false
    length: 0
    precision: 38
    multiValued: false
    searchable: true
    physicalName: ID
    label: ID
    description: The unique identifier for the legal entity.
    documentation: A system-generated unique identifier for each legal entity record.
  - _name: Name
    dataType: String
    _type: EntityAttribute
    mandatory: true
    mandatoryValidationScope: PRE_CONSO
    i18ned: false
    length: 128
    multiValued: false
    searchable: true
    physicalName: NAME
    label: Name
    description: The name of the legal entity.
    documentation: The official name or title of the legal entity.
  - _name: NormalizedName
    dataType: String
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    multiValued: false
    searchable: true
    physicalName: NORMALIZED_NAME
    label: Normalized Name
    description: The normalized name of the legal entity.
    documentation: The standardized or normalized version of the legal entity's name for matching and deduplication.
  - _name: FiscalYear
    dataType: Boolean
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 0
    multiValued: false
    searchable: true
    physicalName: FISCAL_YEAR
    label: Fiscal Year
    description: Indicates if the legal entity has a fiscal year.
    documentation: Boolean flag indicating whether the legal entity has a fiscal year defined.
  - _name: FiscalYearEnd
    dataType: LegalEntity.list_of_values.FiscalYearEnd
    lovValidationScope: PRE_CONSO
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    multiValued: false
    searchable: true
    physicalName: FISCAL_YEAR_END
    label: Fiscal Year End
    description: The fiscal year end for the legal entity.
    documentation: The month or date when the legal entity's fiscal year ends.
  - _name: Revenue
    dataType: Integer
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 20
    precision: 10
    multiValued: false
    searchable: true
    physicalName: REVENUE
    label: Revenue
    description: The revenue of the legal entity.
    documentation: The annual or reported revenue for the legal entity.
  - _name: USFEIN
    dataType: String
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 10
    multiValued: false
    searchable: true
    physicalName: US_FEIN
    label: US FEIN
    description: The US Federal Employer Identification Number (FEIN) for the legal entity.
    documentation: The FEIN is a unique identifier assigned to businesses by the IRS in the United States.
  - _name: SSN
    dataType: String
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 20
    multiValued: false
    searchable: true
    physicalName: SSN
    label: SSN
    description: The Social Security Number (SSN) for the legal entity.
    documentation: The SSN is a unique identifier used for individuals and some entities in the United States.
  - _name: InputAddress 
    dataType: LegalEntity.complex_types.InputAddressType
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 128
    multiValued: false
    searchable: true
    physicalName: INP
    label: Input Address
    description: The input address for the legal entity.
    documentation: The address provided for the legal entity, including street, city, state, and country.
  - _name: GeocodedAddress
    dataType: LegalEntity.complex_types.GeocodedAddressType
