_package: LegalEntity.entities.LegalEntity.validations
_name: DetectSpecialCharacter
_type: SemQLValidation
condition: "REGEXP_LIKE(Name, '^[^a-zA-Z0-9].*')"
validationLabel: Name must not start with special characters
validationScope: PRE_CONSO
label: Detect Special Character
description: Name must not start with special characters
entity: LegalEntity.entities.LegalEntity.LegalEntity
