    i18ned: false
    length: 128
    multiValued: false
    searchable: true
    physicalName: STRATEGY
    label: Strategy
    description: The name or identifier of the strategy.
    documentation: This attribute stores the unique name of the strategy, which is used to distinguish different strategic approaches.
  - _name: Description
    dataType: String
    _type: EntityAttribute
    mandatory: false
    i18ned: false
    length: 4000
    multiValued: false
    searchable: true
    physicalName: DESCRIPTION
    label: Description
    description: Detailed information about the strategy.
    documentation: Provides additional context or notes about the strategy, such as its objectives, scope, or implementation details.
