## This file defines the Strategy entity for the Legal Entity application.
## It includes attributes and properties for managing strategy values.
_package: LegalEntity.entities.Strategy
_type: Entity
_name: Strategy
label: Strategy
pluralLabel: Strategies
iconUrl: images://le-img-lib/sign-direction.svg
description: Represents a business strategy associated with a legal entity, used to define and categorize strategic approaches within the organization.
documentation: The Strategy entity captures the strategic direction or approach for a legal entity. It is used to classify and manage different strategies, supporting business analysis and reporting.
enableDelete: true
attributes: 
  - _name: Strategy
    dataType: String
    _type: EntityAttribute
    mandatory: true
