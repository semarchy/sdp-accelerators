# This is a main application definition file for Legal Entity application
_package: LegalEntity.applications
_type: Application
_name: LegalEntities
label: Legal Entities
applicationTitle: Legal Entities
description: Application to manage Legal Entities
visibility: VISIBLE
titleColor: md:green
avatarImageUrl: images://le-img-lib/office-building.svg
logoUrl: images://le-img-lib/logo.png
coverImageUrl: images://le-img-lib/cover.png
favIcon: images://le-img-lib/office-building.svg
sortStrategy: POSITION
historyBrowsingEnabled: true
historyBrowsingRequiredRole: ''
navDrawer:
    - _type: FolderNavGroup
      _name: TopActionsNavigation
      dividerVisible: true
      labelVisible: false
      linkedFolder: LegalEntity.applications.LegalEntities.Root.TopActions
    - _type: FolderNavGroup
      _name: LegalEntityNavigation
      dividerVisible: true
      labelVisible: false
      linkedFolder: LegalEntity.applications.LegalEntities.Root.LegalEntity
    - _type: FolderNavGroup
      _name: ReferenceDataNavigation
      dividerVisible: true
      labelVisible: false
      linkedFolder: LegalEntity.applications.LegalEntities.Root.ReferenceData
    - _type: FolderNavGroup
      _name: AdministrationNavigation
      dividerVisible: true
      labelVisible: false
      linkedFolder: LegalEntity.applications.LegalEntities.Root.Administration

documentationConfig:
  documentation: Legal entity diagram
  documentationConfigDiagrams:
    - _type: DocumentationConfigDiagram
      _name: LegalEntityDiagram
      label: Legal Entity Diagram
      modelDiagram: LegalEntity.model_diagrams.LegalEntityDiagram
defaultAction: LegalEntity.applications.LegalEntities.Root.TopActions.Inbox
rootFolder:
  _type: FolderAction
  _name: Root
  label: Top
  description: Top
  icon: images://le-img-lib/folder.svg
  imageAlign: MIDDLE_CENTER
  imageMode: FIT
  appActions:
    - _name: TopActions
      _type: FolderAction
      imageAlign: MIDDLE_CENTER
      imageMode: FIT
      label: Quick links
      appActions:
      - _name: GlobalSearchConfig
        _type: GlobalSearchAction
        icon: images://le-img-lib/magnify.svg
        iconColor: md:blue
        imageAlign: MIDDLE_CENTER
        imageMode: FIT
        label: Search
      - _name: Inbox
        _type: MyTasksAction
        badgeVisible: true
        imageAlign: MIDDLE_CENTER
        imageMode: FIT
      - _name: StartHere
        _type: FolderAction
