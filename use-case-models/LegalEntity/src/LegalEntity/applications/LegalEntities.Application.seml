globalSearchConfig:
  displaySearchForDropdown: true
  sortBusinessViewsAlphabetically: false
  globalSearchBusinessViews:
    - _type: GlobalSearchBoView
      _name: LegalEntity
      viewType: GD
      businessView: LegalEntity.entities.LegalEntity.business_views.LegalEntityBusinessView
      searchTypeConfig: LegalEntity.entities.LegalEntity.business_views.LegalEntityBusinessView.LegalEntity.TextConfig
      maxResults: 5       